<Window x:Class="Group4337.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ЛР3+ЛР4 - Вариант 8 (Гильманова)" Height="450" Width="400">
    <StackPanel Margin="20" VerticalAlignment="Center">
        <Button Content="Информация об авторе" Click="ShowInfo_Click" Height="40" Margin="5"/>

        <Button Content="Импорт данных (Excel)" Click="ImportButton_Click" Height="40" Margin="5"/>
        <Button Content="Экспорт в Excel" Click="ExportButton_Click" Height="40" Margin="5"/>

        <Separator Margin="0,15,0,15"/>

        <Button Content="Импорт JSON данных" Click="ImportJsonButton_Click" Height="40" Margin="5" Background="LightYellow"/>
        <Button Content="Экспорт в Word" Click="ExportWordButton_Click" Height="40" Margin="5" Background="LightGreen"/>
    </StackPanel>
</Window>